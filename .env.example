# Copy to .env.local and fill in your Supabase project values.
# Without these, the app runs entirely on in-memory seed data (no persistence).
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# NOTE: the Gemini API key is NOT set here. It lives only as a Supabase Edge
# Function secret (server-side), never in client env:
#   supabase secrets set GEMINI_API_KEY=your-google-ai-studio-key
